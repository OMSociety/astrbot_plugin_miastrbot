# miastrbot 配置文件示例
# 复制此文件为 config.yaml 并填写配置

# ========== 小爱音箱 ==========
speaker:
  user_id: ""                 # 从 account.xiaomi.com Cookie 中提取 userId
  service_token: ""          # 从 Cookie 中提取 serviceToken（micoapi）
  device_id: ""              # 留空则自动选择第一个设备
  hardware: "L05C"            # L05C/LX06/LX04/X10A/L05B
  ai_mode: true               # true：启用小爱语音 Agent 处理；false：仅轮询不交给 AI
  provider_mode: "default"   # default=跟随 AstrBot 默认提供商；select/custom=使用 provider_id
  provider_id: ""            # 可选，填写 AstrBot 里已配置的聊天提供商 ID
  persona_mode: "inherit"    # inherit=继承 AstrBot 默认人格；select=选择已有 persona_id；custom=使用下方 persona_prompt；none=不注入人格
  persona_id: ""             # 可选，填写 AstrBot 里已存在的人格 ID
  persona_prompt: |
    你是芙兰，住在红魔馆的少女。
    当用户用“芙兰”唤醒你时，你要像熟悉的私人语音助手一样回答。
    回答要简短、自然、适合语音播报，不要太书面，不要输出 Markdown。

# ========== 天气查询 ==========
weather:
  weather_api_key: ""        # 心知天气 API Key（免费申请）
  weather_city: "北京"         # 默认查询城市

# ========== TTS 播报 ==========
tts:
  engine: "edge"             # edge（免费，推荐）/ openai / azure / native / volcengine
  type: "edge"               # 兼容旧版本配置，建议使用 engine 作为主配置键
  voice: "zh-CN-XiaoxiaoNeural"
  rate: "+0%"                # +10% 加速，-10% 减速
  volcengine_appid: ""       # 火山云 AppID（engine=volcengine 时必填）
  volcengine_access_token: "" # 火山云 Access Token（必填）
  volcengine_voice_type: ""  # 火山云音色 ID（Speaker ID，必填）
  volcengine_sample_rate: 24000
  volcengine_speed_ratio: 0  # -50 到 100
  volcengine_loudness_rate: 0 # -50 到 100

# ========== WebUI 管理面板 ==========
webui:
  enable: true               # 关闭后可节省资源
  host: "0.0.0.0"
  port: 9528
  password: ""               # 留空无密码保护
  auto_kill: false           # 端口冲突时自动清理旧进程
