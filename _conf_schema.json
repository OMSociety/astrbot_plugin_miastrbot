{
    "speaker": {
        "description": "小爱音箱配置",
        "type": "object",
        "items": {
            "user_id": {
                "description": "小米账号 UserId",
                "type": "string",
                "default": "",
                "hint": "从 Cookie 中提取，以 0 开头"
            },
            "service_token": {
                "description": "Service Token",
                "type": "string",
                "default": "",
                "obvious_hint": true,
                "hint": "从 Cookie 中提取，很长的一串字符"
            },
            "device_id": {
                "description": "设备 DID",
                "type": "string",
                "default": "",
                "hint": "留空自动选择第一个音箱"
            },
            "hardware": {
                "description": "音箱型号",
                "type": "string",
                "default": "L05C",
                "hint": "L05C(Play增强版) / LX06(Pro) / LX04 / X10A / L05B / L07A"
            },
            "ai_mode": {
                "description": "AI 对话模式",
                "type": "bool",
                "default": false,
                "hint": "开启后私聊消息直接进 AI 意图识别"
            },
            "wake_words": {
                "description": "唤醒词",
                "type": "string",
                "default": "",
                "hint": "示例：小爱。说出唤醒词后进入 LLM 对话模式"
            },
            "model": {
                "description": "LLM 模型",
                "type": "string",
                "default": "gpt-4o-mini",
                "hint": "用于意图识别和闲聊"
            },
            "command_prefix": {
                "description": "命令前缀",
                "type": "string",
                "default": "/小爱",
                "hint": "逗号分隔，带此前缀才当作命令处理"
            }
        }
    },
    "mihome": {
        "description": "米家设备控制（扫码授权后自动生成配置）",
        "type": "object",
        "items": {}
    },
    "weather": {
        "description": "天气查询配置",
        "type": "object",
        "items": {
            "weather_api_key": {
                "description": "心知天气 API Key",
                "type": "string",
                "default": "",
                "hint": "从 https://www.seniverse.com 免费申请"
            },
            "weather_city": {
                "description": "默认城市",
                "type": "string",
                "default": "北京"
            }
        }
    },
    "tts": {
        "description": "TTS 播报配置",
        "type": "object",
        "items": {
            "engine": {
                "description": "TTS 引擎",
                "type": "string",
                "default": "edge",
                "hint": "edge（免费，推荐）/ openai / native / volcengine"
            },
            "voice": {
                "description": "语音角色",
                "type": "string",
                "default": "zh-CN-XiaoxiaoNeural",
                "hint": "推荐：zh-CN-XiaoxiaoNeural（晓晓）"
            },
            "rate": {
                "description": "语速",
                "type": "string",
                "default": "+0%",
                "hint": "+10% 加速，-10% 减速"
            },
            "volcengine_appid": {
                "description": "火山云 AppID",
                "type": "string",
                "default": "",
                "hint": "使用 volcengine 引擎时必填"
            },
            "volcengine_access_token": {
                "description": "火山云 Access Token",
                "type": "string",
                "default": "",
                "obvious_hint": true
            },
            "volcengine_voice_type": {
                "description": "火山云音色 ID",
                "type": "string",
                "default": "",
                "hint": "音色克隆生成的 Speaker ID"
            },
            "volcengine_sample_rate": {
                "description": "火山云采样率",
                "type": "int",
                "default": 24000
            },
            "volcengine_speed_ratio": {
                "description": "火山云语速",
                "type": "int",
                "default": 0,
                "hint": "-50 到 100"
            },
            "volcengine_loudness_rate": {
                "description": "火山云音量",
                "type": "int",
                "default": 0,
                "hint": "-50 到 100"
            }
        }
    },
    "webui": {
        "description": "WebUI 管理面板",
        "type": "object",
        "items": {
            "enable": {
                "description": "启用面板",
                "type": "bool",
                "default": true,
                "hint": "关闭后可节省资源"
            },
            "host": {
                "description": "监听地址",
                "type": "string",
                "default": "127.0.0.1"
            },
            "port": {
                "description": "端口",
                "type": "int",
                "default": 9527
            },
            "password": {
                "description": "访问密码",
                "type": "string",
                "default": "",
                "hint": "留空则无密码保护"
            },
            "auto_kill": {
                "description": "端口冲突时自动清理",
                "type": "bool",
                "default": false
            }
        }
    }
}
