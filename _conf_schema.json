{
    "speaker": {
        "description": "小爱音箱配置",
        "type": "object",
        "items": {
            "user_id": {
                "description": "小米账号 UserId",
                "type": "string",
                "default": "",
                "hint": "从 Cookie 中提取 userId（数字 ID），并非 cUserId。若配置了账号密码则自动获取，无需填"
            },
            "account": {
                "description": "小米账号（手机号/邮箱/小米ID）",
                "type": "string",
                "default": "",
                "hint": "配置账号密码后自动登录获取 token，无需手动填 user_id/service_token"
            },
            "password": {
                "description": "小米账号密码",
                "type": "string",
                "default": "",
                "obvious_hint": true,
                "hint": "与 account 配合使用，自动登录获取有效 token"
            },
            "service_token": {
                "description": "Service Token",
                "type": "string",
                "default": "",
                "obvious_hint": true,
                "hint": "必须从 micommand.mina.mi.com 或 api.mina.mi.com 域名抓取，不能用 account.xiaomi.com 的 token"
            },
            "device_id": {
                "description": "设备 DID",
                "type": "string",
                "default": "",
                "hint": "留空自动选择第一个音箱"
            },
            "hardware": {
                "description": "音箱型号",
                "type": "string",
                "default": "L05C",
                "hint": "L05C(Play增强版) / LX06(Pro) / LX04 / X10A / L05B / L07A"
            },
            "ai_mode": {
                "description": "启用小爱语音 Agent",
                "type": "bool",
                "default": true,
                "hint": "控制小爱音箱语音是否转交给 Agent 处理。"
            },
            "wake_words": {
                "description": "唤醒词",
                "type": "string",
                "default": "",
                "hint": "示例：小爱。说出唤醒词后进入 LLM 对话模式"
            },
            "provider_mode": {
                "description": "语音对话模型提供商模式",
                "type": "string",
                "default": "default",
                "options": ["default", "select", "custom"],
                "hint": "default=跟随 AstrBot 默认提供商；select=从下方下拉选择已配置 provider；custom=手填 provider_id"
            },
            "provider_id": {
                "description": "语音对话模型提供商",
                "type": "string",
                "default": "",
                "_special": "select_provider",
                "hint": "当 provider_mode=select 时，从 AstrBot 已配置的聊天提供商中选择"
            },
            "persona_mode": {
                "description": "语音人格模式",
                "type": "string",
                "default": "inherit",
                "options": ["inherit", "select", "custom", "none"],
                "hint": "inherit=继承 AstrBot 默认人格；select=从下方下拉选择已有人格；custom=使用下方 persona_prompt；none=不注入人格"
            },
            "persona_id": {
                "description": "语音人格",
                "type": "string",
                "default": "",
                "_special": "select_persona",
                "hint": "当 persona_mode=select 时，从 AstrBot 已配置人格中选择"
            },
            "persona_prompt": {
                "description": "小爱语音人格提示词",
                "type": "string",
                "default": "",
                "hint": "仅用于小爱语音对话的人格设定，例如说话风格、身份、自称、禁忌等"
            }
        }
    },
    "mihome": {
        "description": "米家设备控制（扫码授权后自动生成配置）",
        "type": "object",
        "items": {}
    },
    "weather": {
        "description": "天气查询配置",
        "type": "object",
        "items": {
            "weather_api_key": {
                "description": "心知天气 API Key",
                "type": "string",
                "default": "",
                "hint": "从 https://www.seniverse.com 免费申请"
            },
            "weather_city": {
                "description": "默认城市",
                "type": "string",
                "default": "北京"
            }
        }
    },
    "tts": {
        "description": "TTS 播报配置",
        "type": "object",
        "items": {
            "engine": {
                "description": "TTS 引擎",
                "type": "string",
                "default": "edge",
                "hint": "edge（免费，推荐）/ openai / native / volcengine"
            },
            "voice": {
                "description": "语音角色",
                "type": "string",
                "default": "zh-CN-XiaoxiaoNeural",
                "hint": "推荐：zh-CN-XiaoxiaoNeural（晓晓）"
            },
            "rate": {
                "description": "语速",
                "type": "string",
                "default": "+0%",
                "hint": "+10% 加速，-10% 减速"
            },
            "volcengine_appid": {
                "description": "火山云 AppID",
                "type": "string",
                "default": "",
                "hint": "使用 volcengine 引擎时必填"
            },
            "volcengine_access_token": {
                "description": "火山云 Access Token",
                "type": "string",
                "default": "",
                "obvious_hint": true
            },
            "volcengine_voice_type": {
                "description": "火山云音色 ID",
                "type": "string",
                "default": "",
                "hint": "音色克隆生成的 Speaker ID"
            },
            "volcengine_sample_rate": {
                "description": "火山云采样率",
                "type": "int",
                "default": 24000
            },
            "volcengine_speed_ratio": {
                "description": "火山云语速",
                "type": "int",
                "default": 0,
                "hint": "-50 到 100"
            },
            "volcengine_loudness_rate": {
                "description": "火山云音量",
                "type": "int",
                "default": 0,
                "hint": "-50 到 100"
            }
        }
    },
    "webui": {
        "description": "WebUI 管理面板",
        "type": "object",
        "items": {
            "enable": {
                "description": "启用面板",
                "type": "bool",
                "default": true,
                "hint": "关闭后可节省资源"
            },
            "host": {
                "description": "监听地址",
                "type": "string",
                "default": "127.0.0.1"
            },
            "port": {
                "description": "端口",
                "type": "int",
                "default": 9527
            },
            "password": {
                "description": "访问密码",
                "type": "string",
                "default": "",
                "hint": "留空则无密码保护"
            },
            "auto_kill": {
                "description": "端口冲突时自动清理",
                "type": "bool",
                "default": false
            }
        }
    }
}
